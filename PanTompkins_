    ax1.legend()

    # FIGURE 2: PROCESSED SIGNAL
    ax2.clear()
    ax2.plot(integrated, color='orange', label="Integrated Signal")
    ax2.scatter(peaks, integrated[peaks], color='red', label="Detected Peaks")
    ax2.set_title("Processed Signal (Pan-Tompkins)")
    ax2.set_xlabel("Samples")
    ax2.set_ylabel("Amplitude (A.U.)")
    ax2.legend()

    # UPDATE
    plt.pause(0.01)
