fs = 250

USE_ARDUINO = False

if USE_ARDUINO:
    ser = serial.Serial('COM3', 115200) # change port
    
def ecg_with_true_peaks(fs=250, duration=5):
    t = np.linspace(0, duration, fs * duration)
    signal = np.zeros_like(t)

    hr = 72
    beat_interval = int(fs * (60 / hr))

    true_peaks = []

    # 🔥 delay before first beat (0.5–1.0 sec)
    start_delay = int(0.8 * fs)

    for i in range(start_delay, len(t), beat_interval):
        if i + 5 < len(t):

            # R peak
            signal[i:i+3] += [0, 1.5, 0]

            # Q and S waves
            if i - 2 >= 0:
                signal[i-2:i+1] += [0, -0.2, 0]
            signal[i+3:i+6] += [0, -0.4, 0]

            true_peaks.append(i + 1)

    # light noise (keep ground truth valid)
    signal += 0.05 * np.random.randn(len(t))

    return signal, np.array(true_peaks)

def synthetic_ecg_clean_noisy(fs=250, duration=5):
    t = np.linspace(0, duration, fs * duration)
    signal = np.zeros_like(t)

    hr = 75
    beat_interval = int(fs * (60 / hr))

    # --- delay before first beat (e.g., 0.5 sec) ---
    start_delay = int(0.5 * fs)

    for i in range(start_delay, len(t), beat_interval):
        if i + 6 < len(t):
            signal[i:i+3] += [0, 1.5, 0]
            signal[i+3:i+6] += [0, -0.5, 0]

    # small noise so it's not perfectly flat
    signal += 0.05 * np.random.randn(len(t))

    return signal

# Test Signal
def synthetic_ecg(fs=250, duration=5):
    t = np.linspace(0, duration, fs * duration)
    signal = np.zeros_like(t)

# --- Variable heart rate (60–110 BPM) ---
    hr = np.random.uniform(60, 110)
    beat_interval = int(fs * (60 / hr))

# --- Delay before first beat (e.g., 0.5–1 sec) ---
    start_delay = int(np.random.uniform(0.5, 1.0) * fs)

    for i in range(start_delay, len(t), beat_interval):
        if i + 10 < len(t):
            # Randomize QRS amplitude and width
            amp = np.random.uniform(0.8, 2.0)
            width = np.random.randint(2, 5)

            signal[i:i+width] += [0] + [amp] + [0]*(width-2)
            signal[i+width:i+2*width] += [0, -0.5*amp] + [0]*(width-2)

# -------------------------
# EXTREME NOISE SOURCES
# -------------------------

    baseline = (
        0.5 * np.sin(2 * np.pi * 0.2 * t) +
        0.3 * np.sin(2 * np.pi * 0.05 * t)
        )

    powerline = (
        0.1 * np.sin(2 * np.pi * 60 * t) +
        0.05 * np.sin(2 * np.pi * 120 * t)
        )

    muscle = 0.3 * np.random.randn(len(t))

    motion = np.zeros_like(t)
    for _ in range(int(duration * 2)):
        idx = np.random.randint(0, len(t)-20)
        motion[idx:idx+20] += np.random.uniform(-2, 2)

    jumps = np.zeros_like(t)
    for _ in range(int(duration)):
        idx = np.random.randint(0, len(t))
        jumps[idx:] += np.random.uniform(-0.5, 0.5)

# -------------------------
# ADD NOISY START (key part)
# -------------------------

# overwrite the beginning with noise (no QRS present)
    signal[:start_delay] = 0.4 * np.random.randn(start_delay)

# occasional dropped beat (keep this AFTER delay logic)
    if np.random.rand() < 0.3:
        skip_idx = np.random.randint(start_delay, len(signal)-beat_interval)
        signal[skip_idx:skip_idx+beat_interval] = 0

# -------------------------
# COMBINE
# -------------------------
    noisy_signal = signal + baseline + powerline + muscle + motion + jumps

    return noisy_signal
   
# Read Serial Data from Arduino
def read_data(n_samples=1000):
    data = []
    if USE_ARDUINO:
        while len(data) < n_samples:
            line = ser.readline().decode().strip()
            if line == "!":
                continue
            try:
                data.append(int(line))
            except:
                pass
    else:
        data, true_peaks = ecg_with_true_peaks(fs, int(n_samples / fs))
        
    return np.array(data), np.array(true_peaks)

## Pan-Tompkins Algorithm

# Bandpass Filter
def bandpass(signal, fs):
    low, high = 5, 20 
    b, a = butter(2, [low/(fs/2), high/(fs/2)], btype='band')
    return filtfilt(b, a, signal)

# Derivative Filter
def derivative(signal):
    return np.convolve(signal, [1, 2, 0, -2, -1], mode='same') / 8

# Squaring Filter
def squaring(signal):
    return signal ** 2

# MWI
def moving_window(signal, fs):
    window_size = int(0.15 * fs)
    return np.convolve(signal, np.ones(window_size) / window_size, mode='same')

# Peak Detection + Threshold
def detect_peaks(integrated, fs):
    distance = int(0.2 * fs) # 200 ms refractory period
    threshold = np.mean(integrated) * 1.2
    
    peaks, _ = find_peaks(integrated, height=threshold, distance=distance)
    
    trim = int(0.2 * fs)
    peaks = peaks[peaks > trim]
    
    return peaks

def heart_rate(peaks, fs):
    if len(peaks) < 2:
        return 0
    rr = np.diff(peaks) / fs
    return 60 / np.mean(rr)

