import serial
import csv
from datetime import datetime
import threading

PORT = 'COM4'      # change if your Arduino is on another COM port
BAUD = 115200

ser = serial.Serial(PORT, BAUD, timeout=1)

print("Waiting for Arduino...")
while True:
    line = ser.readline().decode(errors='ignore').strip()
    if line:
        print(line)
    if line == "READY":
        break

print("Connected.\n")

def send_cmd(cmd):
    ser.write((cmd + '\n').encode())
    print(f">>> {cmd}")

timestamp = datetime.now().strftime("%m-%d_%H-%M")
filename = f"pressure_data_{timestamp}.csv"

file = open(filename, "w", newline="")
writer = csv.writer(file)
writer.writerow(["time_ms", "pressure_mmHg"])
file.flush()

def reader():
    while True:
        line = ser.readline().decode(errors='ignore').strip()
        if not line:
            continue

        print(line)

        parts = line.split(",")
        if len(parts) == 2:
            try:
                t = int(parts[0])
                p = float(parts[1])
                writer.writerow([t, p])
                file.flush()
            except:
                pass

        elif line.startswith("ACK"):
            print("Command confirmed:", line)

def command():
    while True:
        cmd = input("Enter command (zero/pump/stop/valve/close/pulse/stream_on/stream_off): ").strip()
        if cmd:
            send_cmd(cmd)

try:
    t1 = threading.Thread(target=reader, daemon=True)
    t2 = threading.Thread(target=command, daemon=True)

    t1.start()
    t2.start()

    t1.join()
    t2.join()

except KeyboardInterrupt:
    print("\nStopping...")

finally:
    file.close()
    ser.close()
